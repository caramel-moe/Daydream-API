diff --git a/src/main/java/org/bukkit/World.java b/src/main/java/org/bukkit/World.java
index c40c594887f5e23734c5477290c17df4c0f2ad6d..67a16f6bf6744c6934d90f3d0294b42dc3f09bfd 100644
